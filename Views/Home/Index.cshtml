@{
    ViewData["Title"] = "Port Home";
}

<!-- ═══ HERO ═══════════════════════════════════════════════ -->
<section class="hero-section">
    <span class="hero-divider">⚓ ☠ ⚓</span>
    <h1 class="hero-title shimmer-text">Pirate Cinema</h1>
    <p class="hero-subtitle">
        "Set sail for the silver screen — where every film is treasure<br />
        and every actor a corsair of the craft."
    </p>
    <span class="hero-divider">☠ ⚓ ☠</span>

    <div class="mt-4 d-flex gap-3 justify-content-center flex-wrap">
        <a asp-controller="Movies" asp-action="Index" class="btn btn-primary btn-lg">
            🎬 Browse the Treasure Chest
        </a>
        <a asp-controller="Actors" asp-action="Index" class="btn btn-secondary btn-lg">
            ⚓ Meet the Crew
        </a>
    </div>
</section>

<hr class="divider-gold" />

<!-- ═══ FEATURE CARDS ═══════════════════════════════════════ -->
<section class="py-3">
    <div class="row g-4">

        <div class="col-md-4">
            <div class="feature-card h-100">
                <span class="feature-icon">🎬</span>
                <h3>The Treasure Chest</h3>
                <p>
                    Browse our legendary collection of films. View posters, explore genres,
                    and read AI-generated reviews complete with sentiment scores — rated by
                    the toughest critics on the seven seas.
                </p>
                <a asp-controller="Movies" asp-action="Index" class="btn btn-primary mt-3">
                    Open the Chest
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card h-100">
                <span class="feature-icon">⚓</span>
                <h3>The Crew</h3>
                <p>
                    Meet the sailors of the silver screen. From seasoned captains to greenhorn
                    deckhands, every actor's reputation is measured by AI-powered scuttlebutt
                    straight off the Twitter crow's nest.
                </p>
                <a asp-controller="Actors" asp-action="Index" class="btn btn-primary mt-3">
                    Meet the Crew
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="feature-card h-100">
                <span class="feature-icon">📜</span>
                <h3>The Ship Manifest</h3>
                <p>
                    Every great voyage requires a proper manifest. Explore which members
                    of the crew sailed aboard which vessels — and keep the record straight
                    for Davy Jones himself.
                </p>
                <a asp-controller="ActorMovies" asp-action="Index" class="btn btn-primary mt-3">
                    Read the Manifest
                </a>
            </div>
        </div>

    </div>
</section>

<hr class="divider-gold" />

<!-- ═══ FLAVOUR TEXT ════════════════════════════════════════ -->
<section class="text-center py-4 parchment mx-auto" style="max-width: 700px;">
    <h2 style="font-family: var(--font-title); color: var(--blood-red);">
        ⚓ About This Port
    </h2>
    <hr style="border-color: var(--wood-mid);" />
    <p>
        Welcome, traveller, to <strong>Pirate Cinema</strong> — the most feared
        film database on the seven seas. Our scholars consult the mystical AI oracle
        to conjure fresh reviews of every motion picture in our hold, and our network
        of spies scours the social seas for word of every crew member aboard.
    </p>
    <p class="mt-3 fst-italic">
        "A smooth sea never made a skilled cinephile."
    </p>
</section>
