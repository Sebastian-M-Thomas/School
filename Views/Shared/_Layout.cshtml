<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Pirate Cinema ☠</title>

    <!--
        ╔══════════════════════════════════════════════════╗
        ║         PIRATE CINEMA — Plunder the Screen       ║
        ║              SRI hashes required!                ║
        ╚══════════════════════════════════════════════════╝
        REMINDER: Replace all integrity="sha384-REPLACE_ME" values
        with real SRI hashes generated from:
        https://www.srihash.org/
    -->
    <!-- Bootstrap CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
          crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+"
          crossorigin="anonymous" />

    <!-- Google Fonts — loaded via CSS import rule in site.css, no SRI needed -->
    <!-- Pirate Cinema Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- ═══ NAVBAR ═══════════════════════════════════════════ -->
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container-xl">

                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Pirate Cinema
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                🏠 Port Home
                            </a>
                        </li>

                        <!-- Movies dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                🎬 The Treasure Chest
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark"
                                style="background: var(--wood-dark); border: 1px solid var(--gold-dim);">
                                <li>
                                    <a class="dropdown-item" asp-controller="Movies" asp-action="Index"
                                       style="font-family: var(--font-accent); color: var(--parchment-dark);">
                                        📜 Browse All Films
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Movies" asp-action="Create"
                                       style="font-family: var(--font-accent); color: var(--parchment-dark);">
                                        ➕ Log New Plunder
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Actors dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                ⚓ The Crew
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark"
                                style="background: var(--wood-dark); border: 1px solid var(--gold-dim);">
                                <li>
                                    <a class="dropdown-item" asp-controller="Actors" asp-action="Index"
                                       style="font-family: var(--font-accent); color: var(--parchment-dark);">
                                        📜 Browse the Crew
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Actors" asp-action="Create"
                                       style="font-family: var(--font-accent); color: var(--parchment-dark);">
                                        ➕ Recruit a Sailor
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Actor-Movie relationships -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ActorMovies" asp-action="Index">
                                🔗 Ship Manifest
                            </a>
                        </li>

                    </ul>

                    
                    
                </div>
            </div>
        </nav>
    </header>

    <!-- ═══ MAIN CONTENT ══════════════════════════════════════ -->
    <main role="main">
        <div class="container-xl">
            @RenderBody()
        </div>
    </main>

    <!-- ═══ FOOTER ════════════════════════════════════════════ -->
    <footer>
        <p>
            &copy; @DateTime.Now.Year Pirate Cinema &mdash;
            <em>"Not all treasure is silver and gold, mate."</em>
        </p>
    </footer>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
            crossorigin="anonymous"></script>

    <!-- jQuery (needed for DataTables / unobtrusive validation) -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"
            integrity="sha384-1H217gwSVyLSIfaLxHbE7dRb3v4mYCKbpQvzx0cegeju1MVsGrX5xXxAvs/HgeFs"
            crossorigin="anonymous"></script>

    <!-- jQuery Unobtrusive Validation -->
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"
            integrity="sha384-aEDtD4n2FLrMdE9psop0SHdNyy/W9cBjH22rSRp+3wPHd62Y32uijc0H2eLmgaSn"
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"
            integrity="sha384-DU2a51mTHKDhpXhTyJQ++hP8L9L8Gc48TlvbzBmUof71V7kNVs4ELmaVJKPxcAGn"
            crossorigin="anonymous"></script>

    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
