@model Spring2026_Project3_smthomas12.ViewModels.MovieDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">
        ← Back to Treasure Chest
    </a>
</div>

<!-- ═══ MOVIE INFO ════════════════════════════════════════════════════ -->
<div class="row g-4 mb-4">

    @if (Model.Poster.Length > 0)
    {
        <div class="col-md-3 text-center">
            <img src="data:image/*;base64,@Convert.ToBase64String(Model.Poster)"
                 alt="@Model.Title poster"
                 class="pirate-poster img-fluid"
                 style="max-height: 400px;" />
        </div>
    }

    <div class="@(Model.Poster.Length > 0 ? "col-md-9" : "col-12")">
        <div class="parchment h-100">
            <h1>@Model.Title</h1>
            <hr style="border-color: var(--wood-mid);" />

            <p><strong>⚓ Genre:</strong> @Model.Genre</p>
            <p><strong>📅 Year:</strong> @Model.Year</p>
            <p>
                <strong>🔗 IMDB:</strong>
                <a href="@Model.ImdbLink" target="_blank" rel="noopener">
                    View on IMDB ↗
                </a>
            </p>

            <hr style="border-color: var(--wood-mid);" />
            <h3>⚓ Crew Aboard This Vessel</h3>
            @if (Model.ActorNames.Any())
            {
                <ul class="crew-list">
                    @foreach (var name in Model.ActorNames)
                    {
                        <li style="color: black;">@name</li>
                    }
                </ul>
            }
            else
            {
                <p class="fst-italic">No crew assigned yet.</p>
            }
        </div>
    </div>
</div>

<hr class="divider-gold" />

<!-- ═══ AI REVIEWS + SENTIMENT ═══════════════════════════════════════ -->
<section>
    <h2>🧙 Oracle's Reviews</h2>
    <p class="fst-italic" style="color: var(--parchment-dark); font-family: var(--font-accent);">
        The mystical AI oracle has spoken — five proclamations about this film from the seven seas.
    </p>

    <!-- Average Sentiment Banner -->
    <div class="sentiment-banner mb-4">
        <div class="text-gold" style="font-family: var(--font-accent); font-size: 1rem;">
            Overall Crew Sentiment
        </div>
        <div class="sentiment-score">
            <span class="@Model.AverageSentimentCss" style="font-size: 1.8rem; padding: 0.4rem 1.2rem;">
                @Model.AverageSentimentLabel
            </span>
        </div>
        <div style="color: var(--parchment-dark); font-family: var(--font-accent); font-size: 0.9rem; margin-top: 0.4rem;">
            Average Compound Score: @Model.AverageSentiment.ToString("F3")
        </div>
    </div>

    <!-- Reviews Table -->
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 70%;">📜 Review</th>
                    <th style="width: 30%;">🔮 Sentiment</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var review in Model.Reviews)
                {
                    <tr>
                        <td style="font-family: var(--font-body); color: black;">
                            @review.Text
                        </td>
                        <td>
                            <span class="@review.CssClass">
                                @review.Label
                            </span>
                            <div style="font-size: 0.8rem; color: var(--rope); margin-top: 0.2rem;">
                                Score: @review.Compound.ToString("F3")
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<hr class="divider-gold" />

<!-- ═══ ACTIONS ════════════════════════════════════════════════════════ -->
<div class="d-flex gap-2 flex-wrap">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
        ✏️ Edit Film
    </a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
        🗑️ Walk the Plank
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        ← Back to Chest
    </a>
</div>
