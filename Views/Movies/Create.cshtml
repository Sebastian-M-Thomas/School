@model Spring2026_Project3_smthomas12.Models.Movie

@{
    ViewData["Title"] = "Log New Plunder";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">← Back to Treasure Chest</a>
</div>

<div class="parchment mx-auto" style="max-width: 700px;">
    <h2>➕ Log New Plunder</h2>
    <hr style="border-color: var(--wood-mid);" />

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" placeholder="e.g. Pirates of the Caribbean" />
            <span asp-validation-for="Title" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ImdbLink" class="form-label"></label>
            <input asp-for="ImdbLink" class="form-control" placeholder="https://www.imdb.com/title/..." />
            <span asp-validation-for="ImdbLink" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Genre" class="form-label"></label>
            <input asp-for="Genre" class="form-control" placeholder="e.g. Adventure, Drama" />
            <span asp-validation-for="Genre" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Year" class="form-label"></label>
            <input asp-for="Year" class="form-control" type="number" placeholder="e.g. 2003" />
            <span asp-validation-for="Year" class="field-validation-error"></span>
        </div>

        <div class="mb-4">
            <label for="posterFile" class="form-label">Poster Image</label>
            <input type="file" name="posterFile" id="posterFile" class="form-control" accept="image/*" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">⚓ Save to Chest</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

