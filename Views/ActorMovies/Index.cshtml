@model IEnumerable<Spring2026_Project3_smthomas12.Models.ActorMovie>

@{
    ViewData["Title"] = "Ship Manifest";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>📜 Ship Manifest</h1>
    <a asp-action="Create" class="btn btn-primary">
        ➕ Assign Sailor to Ship
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>⚓ Sailor (Actor)</th>
                <th>🎬 Ship (Movie)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="font-family: var(--font-accent); color: var(--gold);">
                        @item.Actor.Name
                    </td>
                    <td style="font-family: var(--font-accent); color: var(--gold);">
                        @item.Movie.Title
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                👁 View
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                🗑️ Remove
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p style="font-family: var(--font-accent); font-size: 1.3rem; color: var(--rope);">
            The manifest be empty! Assign sailors to their ships.
        </p>
        <a asp-action="Create" class="btn btn-primary btn-lg mt-2">➕ First Assignment</a>
    </div>
}
