@model Spring2026_Project3_smthomas12.Models.ActorMovie

@{
    ViewData["Title"] = "Assign Sailor to Ship";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">← Back to Manifest</a>
</div>

<div class="parchment mx-auto" style="max-width: 600px;">
    <h2>➕ Assign Sailor to Ship</h2>
    <hr style="border-color: var(--wood-mid);" />

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="mb-3">
            <label asp-for="ActorId" class="form-label">⚓ Sailor (Actor)</label>
            <select asp-for="ActorId" class="form-select"
                    asp-items="@(ViewBag.ActorId as SelectList)">
                <option value="">-- Choose a Sailor --</option>
            </select>
            <span asp-validation-for="ActorId" class="field-validation-error"></span>
        </div>

        <div class="mb-4">
            <label asp-for="MovieId" class="form-label">🎬 Ship (Movie)</label>
            <select asp-for="MovieId" class="form-select"
                    asp-items="@(ViewBag.MovieId as SelectList)">
                <option value="">-- Choose a Ship --</option>
            </select>
            <span asp-validation-for="MovieId" class="field-validation-error"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">⚓ Add to Manifest</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
